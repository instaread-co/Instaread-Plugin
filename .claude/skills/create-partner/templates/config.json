{
  "partner_id": "PARTNER_ID",
  "domain": "DOMAIN.TLD",
  "publication": "PARTNER_ID",
  "injection_context": "post",
  "injection_strategy": "first",
  "force_disable_logs": true,
  "clear_page_cache_on_upgrade": true,
  "enqueue_remote_player_script_sitewide": true,
  "injection_rules": [
    {
      "target_selector": "SELECTOR_OR_EMPTY",
      "insert_position": "before_element",
      "exclude_slugs": [
        "/",
        "/privacy-policy/",
        "/terms-of-service/",
        "/terms-of-use/",
        "/about/",
        "/about-us/",
        "/contact/",
        "/contact-us/",
        "/advertise/",
        "/advertise-with-us/",
        "/shop/",
        "/cart/",
        "/checkout/",
        "/my-account/"
      ]
    }
  ],
  "version": "FLEET_VERSION"
}
