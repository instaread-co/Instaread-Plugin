{
  "partner_id": "gardenandgun",
  "domain": "gardenandgun.com",
  "publication": "gardenandgun",
  "injection_context": "post",
  "injection_strategy": "first",
  "injection_rules": [
    {
      "target_selector": ".article-content",
      "insert_position": "prepend",
      "exclude_slugs": [
        "privacy-policy",
        "terms"
      ]
    },
    {
      "target_selector": ".p2",
      "insert_position": "prepend",
      "exclude_slugs": [
        "contact",
        "about"
      ]
    }
  ],
  "version": "4.6.0",
  "force_disable_logs": true,
  "clear_page_cache_on_upgrade": true
}
