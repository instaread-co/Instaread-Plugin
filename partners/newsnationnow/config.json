{
  "partner_id": "newsnationnow",
  "domain": "newsnationnow.com",
  "publication": "newsnationnow",
  "injection_context": "post",
  "injection_strategy": "first",
  "injection_rules": [
    {
      "target_selector": ".article-content",
      "insert_position": "inside_first_child",
      "exclude_slugs": [
        "/",
        "/about/",
        "/contact-us/",
        "/meet-the-team/",
        "/newsnation-tv-schedule/",
        "/closed-captioning/"
      ]
    }
  ],
  "version": "4.5.9",
  "force_disable_logs": true,
  "clear_page_cache_on_upgrade": true
}
