{
  "partner_id": "oversixty",
  "domain": "oversixty.com.au",
  "publication": "oversixty",
  "injection_context": ["editorial", "post"],
  "injection_strategy": "first",
  "force_disable_logs": true,
  "clear_page_cache_on_upgrade": true,
  "enqueue_remote_player_script_sitewide": true,
  "injection_rules": [
    {
      "target_selector": ".article-body p",
      "insert_position": "before_element",
      "exclude_slugs": [
        "/",
        "/privacy-policy/",
        "/terms-of-service/",
        "/terms-of-use/",
        "/about/",
        "/about-us/",
        "/contact/",
        "/contact-us/",
        "/advertise/",
        "/advertise-with-us/",
        "/shop/",
        "/cart/",
        "/checkout/",
        "/my-account/"
      ]
    }
  ],
  "version": "4.7.2"
}
