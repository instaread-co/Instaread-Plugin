{
  "partner_id": "spikedonline",
  "domain": "spiked-online.com",
  "publication": "spikedonline",
  "injection_context": "post",
  "injection_strategy": "first",
  "force_disable_logs": true,
  "clear_page_cache_on_upgrade": true,
  "enqueue_remote_player_script_sitewide": true,
  "injection_rules": [
    {
      "target_selector": ".cms p",
      "insert_position": "after_element",
      "exclude_slugs": [
        "/",
        "/privacy-policy/",
        "/terms-of-service/",
        "/terms-of-use/",
        "/about/",
        "/about-us/",
        "/contact/",
        "/contact-us/",
        "/advertise/",
        "/advertise-with-us/",
        "/shop/",
        "/cart/",
        "/checkout/",
        "/my-account/",
        "/support-us/"
      ]
    }
  ],
  "version": "4.7.3"
}
